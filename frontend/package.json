{
  "name": "frontend",
  "private": true,
  "version": "0.0.0",
  "type": "module",
    "build": {
    "appId": "com.axon.desktop",
    "productName": "AXON",

    "directories": {
      "output": "release"
    },

    "files": [
      "dist/**/*",
      "startup/**/*",
      "electron.cjs",
      "loading.html",
      "package.json"
    ],

    "extraResources": [
      {
        "from": "../backend/dist",
        "to": "backend",
        "filter": [
          "AXONBackend.exe"
        ]
      }
    ],

    "win": {
      "target": "nsis",
      "icon": "build/icon.ico"
    },

    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true
    }
  },
 "scripts": {
  "dev": "vite",
  "build": "vite build",
  "preview": "vite preview",

  "electron": "electron .",

  "desktop": "concurrently \"npm run dev\" \"wait-on http://localhost:5173 && electron .\"",
  "dist-electron": "npm run build && electron-builder"
  
},
  "dependencies": {
    "@tailwindcss/vite": "^4.3.1",
    "axios": "^1.18.1",
    "lucide-react": "^1.22.0",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "react-icons": "^5.7.0",
    "react-router-dom": "^7.18.0",
    "tailwindcss": "^4.3.1"
  },
  "devDependencies": {
    "@babel/core": "^7.29.7",
    "@eslint/js": "^10.0.1",
    "@rolldown/plugin-babel": "^0.2.3",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.2",
    "babel-plugin-react-compiler": "^1.0.0",
    "concurrently": "^10.0.3",
    "electron": "^43.0.0",
    "electron-builder": "^26.15.3",
    "eslint": "^10.5.0",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.3",
    "globals": "^17.6.0",
    "vite": "^8.1.0",
    "wait-on": "^9.0.10"
  },
  "main": "electron.cjs"
}
